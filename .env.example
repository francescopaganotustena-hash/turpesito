# Feature flag Eventi:
# false = sezione eventi nascosta
# true  = sezione eventi visibile (menu, home, pagina /eventi)
VITE_ENABLE_EVENTS=false

# Feature flag Form Contatti:
# false = nasconde "Invia una richiesta" in /contatti
# true  = mostra il form completo in /contatti
VITE_ENABLE_CONTACT_FORM=false

# Feature flag Music Preview Home:
# false = nasconde la sezione "Ultime uscite" in Home
# true  = mostra la sezione "Ultime uscite" in Home
VITE_ENABLE_HOME_MUSIC_PREVIEW=false

# Feature flag Pagina Musica:
# false = nasconde voce menu "Musica" e disattiva la pagina /musica
# true  = abilita pagina e navigazione "Musica"
VITE_ENABLE_MUSIC_PAGE=false

# Feature flag Pagina Video:
# false = nasconde voce menu "Video" e disattiva la pagina /video
# true  = abilita pagina e navigazione "Video"
VITE_ENABLE_VIDEO_PAGE=true

# Feature flag Video Preview Home (modalita Instagram):
# false = usa la preview video classica in Home (dati da src/data/index.ts)
# true  = mostra in Home le card Reel Instagram (senza iframe)
VITE_ENABLE_INSTAGRAM_VIDEO_EMBEDS=true

# Feature flag Scroll Reveal:
# false = disattiva le animazioni in ingresso delle sezioni in scroll
# true  = abilita effetto reveal progressivo
VITE_ENABLE_SCROLL_REVEAL=true

# Feature flag WhatsApp Floating Button:
# false = nasconde il pulsante WhatsApp fisso in basso a destra
# true  = mostra il pulsante flottante in tutte le pagine
VITE_ENABLE_WHATSAPP_FLOATING_BUTTON=true

# Feature flag Media Lazy Loading:
# false = carica subito i video pesanti (comportamento legacy)
# true  = carica i video solo quando sono vicini al viewport
VITE_ENABLE_MEDIA_LAZY_LOADING=true

# Feature flag Media Autoplay:
# false = disattiva autoplay sui video pesanti (risparmio banda/CPU)
# true  = riattiva autoplay automatico (comportamento legacy)
VITE_ENABLE_MEDIA_AUTOPLAY=false
